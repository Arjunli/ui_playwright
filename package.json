{
  "name": "ui-playwright-midscene",
  "version": "2.0.0",
  "description": "基于 Midscene AI 的 Playwright UI 自动化测试框架 - 用自然语言驱动测试",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:web": "playwright test tests/web --project=chromium-web",
    "test:mobile": "playwright test tests/mobile --project=mobile-iphone",
    "report": "npx playwright show-report reports/html-report"
  },
  "keywords": [
    "playwright",
    "midscene",
    "ai-testing",
    "automation",
    "e2e",
    "natural-language"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@midscene/web": "^1.0.0",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  }
}